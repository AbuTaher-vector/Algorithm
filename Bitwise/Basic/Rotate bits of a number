#include<bits/stdc++.h>
using namespace std;
#define nn int
#define dd double
#define ll long long int
#define ss string
#define nl '\n'
int main()
{ 
      /*Bit Rotation: A rotation (or circular shift) is an operation similar to shift except 
      that the bits that fall off at one end are put back to the other end. 
      In left rotation, the bits that fall off at left end are put back at right end. 
      In right rotation, the bits that fall off at right end are put back at left end.
      */
      nn n,x;
      cin>>n>>x;
      cout<<"Left rotation of "<<n<<" is "<<((n<<x) | (n>>(32-x)))<<nl; 
      cout<<"Right rotation of "<<n<<" is "<<((n>>x) | (n<<(32-x)))<<nl;                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   
    
