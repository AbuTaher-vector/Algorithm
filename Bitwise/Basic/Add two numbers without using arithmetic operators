#include<bits/stdc++.h>
using namespace std;
#define nn int
#define dd double
#define ll long long int 
#define ss string
#define nl "\n"
int main()
{ 
   /*
   Link: https://www.geeksforgeeks.org/add-two-numbers-without-using-arithmetic-operators/
   */

   nn a,b;
   cin>>a>>b;
   while(b!=0)
   {
         nn carry=(a&b);
         a=a^b;
         b=carry<<1;
   }
   cout<<a<<nl;


}
