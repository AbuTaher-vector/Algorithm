#include<bits/stdc++.h>
using namespace std;
#define nn int
#define dd double
#define ll long long int 
#define ss string
#define nl "\n"
int main()
{ 
    /*

     link : https://www.geeksforgeeks.org/xor-counts-0s-1s-binary-representation/
     */
    nn n;
    cin>>n;
    nn a=0,b=0;
    while(n)
    {
        if(n&1) a++;
        else b++;
        n>>=1;

    }
    cout<<(a^b)<<nl;
     
}
