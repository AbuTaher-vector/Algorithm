#include<bits/stdc++.h>
using namespace std;
#define nn int
#define dd double
#define ll long long int
#define ss string
#define nl '\n'
void addEdge(vector<nn>graph[], nn u,nn v)
{
     graph[u].push_back(v);
     graph[v].push_back(u);
}
int main()
{
     nn v=5;
     vector<nn>graph[v];
     addEdge(graph, 0, 1);
     addEdge(graph, 0, 4);
     addEdge(graph, 1, 2);
     addEdge(graph, 1, 3);
     addEdge(graph, 1, 4);
     addEdge(graph, 2, 3);
     addEdge(graph, 3, 4);

     
     //this representation calls adjacency list 
     for(nn i=0;i<v;i++) 
     {
          cout<<i;
          for(auto x:graph[i]) cout<<"->"<<x;
               cout<<nl;
     }

}
