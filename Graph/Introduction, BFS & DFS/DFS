#include<bits/stdc++.h>
using namespace std;
#define nn int
#define dd double
#define ll long long int
#define ss string
#define nl '\n'
const nn n=1e5;
vector<nn>adj[n];
bool visit[n];
void dfs(nn node)
{
     visit[node]=1;
     cout<<node<<" ";
     for(auto it:adj[node])
     {
          if(!visit[it]) dfs(it);
     }
}
int main()
{
     nn n,m;
     cin>>n>>m;
     nn a,b;
     while(m--)
     {
          cin>>a>>b;
          adj[a].push_back(b);
          adj[b].push_back(a);
     }
     dfs(1);

}
