     /*https://www.geeksforgeeks.org/find-sum-odd-factors-number/*/
     nn n;
     cin>>n;
     nn sum=0;
     for(nn i=1;i<=n/2;i++)
     {
          if(n%i==0 && i%2==1) sum+=i;
     }
     cout<<sum<<nl;

